{
  "name": "@workspace/arpg-game",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "gen:asset-manifest": "node --input-type=module <<'EOF'\nimport fs from 'fs'; import path from 'path'; import crypto from 'crypto';\nconst NS='6ba7b810-9dad-11d1-80b4-00c04fd430c8'.replace(/-/g,'');\nfunction v5(name){const b=Buffer.from(NS,'hex');const h=crypto.createHash('sha1');h.update(b);h.update(Buffer.from(name));const d=h.digest();d[6]=(d[6]&0x0f)|0x50;d[8]=(d[8]&0x3f)|0x80;const x=d.toString('hex');return[x.slice(0,8),x.slice(8,12),x.slice(12,16),x.slice(16,20),x.slice(20,32)].join('-');}\nfunction walk(dir){return fs.readdirSync(dir,{withFileTypes:true}).flatMap(e=>e.isDirectory()?walk(path.join(dir,e.name)):[path.join(dir,e.name)]);}\nconst types={'gltf':'model_gltf','glb':'model_gltf','fbx':'model_fbx','png':'texture_png','jpg':'texture_jpg','bin':'bin'};\nconst all=walk('public').filter(p=>{const e=p.split('.').pop();return types[e];});\nconst m={};\nfor(const f of all){const rel=f.replace(/\\\\/g,'/').replace(/^\\/*/,'');const ext=rel.split('.').pop();const id=v5(rel);m[id]={id,name:path.basename(rel,'.'+ext),path:'/'+rel,type:types[ext]||'unknown',category:rel.split('/').slice(1,-1).join('/')};}\nfs.writeFileSync('src/game/asset-manifest.json',JSON.stringify(m,null,2));\nconsole.log('Manifest: '+Object.keys(m).length+' assets');\nEOF"
  },
