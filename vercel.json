{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install",
  "outputDirectory": "artifacts/website/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://survival-api-production.up.railway.app/api/:path*" },
    { "source": "/arpg-game", "destination": "/arpg-game/index.html" },
    { "source": "/arpg-game/", "destination": "/arpg-game/index.html" },
    { "source": "/arpg-game/:path*", "destination": "/arpg-game/index.html" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/", "destination": "/admin/index.html" },
    { "source": "/admin/:path*", "destination": "/admin/:path*" },
    { "source": "/asset-studio", "destination": "/asset-studio/index.html" },
    { "source": "/asset-studio/", "destination": "/asset-studio/index.html" },
    { "source": "/asset-studio/:path*", "destination": "/asset-studio/:path*" },
    { "source": "/info.html", "destination": "/info.html" },
    { "source": "/lore.html", "destination": "/lore.html" },
    { "source": "/stats-guide.html", "destination": "/stats-guide.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
{ "key": "Content-Security-Policy", "value": "frame-ancestors 'self' https://id.grudge-studio.com https://*.grudge-studio.com https://puter.com https://*.puter.com https://*.puter.site" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/arpg-game/assets/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/arpg-game/models/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/arpg-game/textures/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/arpg-game/locations/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/arpg-game/icons/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    }
  ]
}
