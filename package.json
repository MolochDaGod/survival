{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"if(!process.env.npm_config_user_agent?.startsWith('pnpm')){console.error('Use pnpm instead');process.exit(1)}\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:website": "pnpm --filter @workspace/website run build",
    "build:game": "pnpm --filter @workspace/arpg-game run build",
    "build:api": "pnpm --filter @workspace/api-server run build",
    "dev:website": "pnpm --filter @workspace/website run dev",
    "dev:game": "pnpm --filter @workspace/arpg-game run dev",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:admin": "pnpm --filter @workspace/admin run dev",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:push:force": "pnpm --filter @workspace/db run push-force",
    "deploy:preview": "vercel deploy --yes --archive=tgz",
    "deploy:prod": "pnpm run build:website && node scripts/vercel-prebuilt.mjs && vercel deploy --prebuilt --prod --yes"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "sharp": "^0.33.5",
    "typescript": "~5.9.2"
  }
}
