# ═══════════════════════════════════════════════════════════════════════════
# Grudge Nexus — Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════

# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://grudge:grudge_dev@localhost:5432/grudge_nexus
POSTGRES_PASSWORD=grudge_dev

# ── Auth & Security ─────────────────────────────────────────────────────────
# JWT_SECRET=your-jwt-secret
# SESSION_SECRET=your-session-secret
# INTERNAL_API_KEY=your-internal-api-key
# ADMIN_TOKEN=your-admin-token (auto-generated if unset in dev)

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Omit in dev to allow all.
# CORS_ORIGINS=https://grudgewarlords.com,https://grudge-studio.com,https://grudges.grudge-studio.com

# ── Cloudflare (DNS + R2 + D1) ──────────────────────────────────────────────
CF_ACCOUNT_ID=your-cloudflare-account-id
# CF_ZONE_ID=your-zone-id
# CF_DNS_API_TOKEN=your-dns-api-token

# ── R2 Object Storage ──────────────────────────────────────────────────────
OBJECT_STORAGE_KEY=your-r2-access-key-id
OBJECT_STORAGE_SECRET=your-r2-secret-access-key
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_PUBLIC_URL=https://assets.grudge-studio.com
# OBJECT_STORAGE_PUBLIC_R2_URL=https://pub-xxxx.r2.dev
R2_BUCKET_ASSETS=grudge-assets
R2_BUCKET_OBJECTSTORE=objectstore-assets

# ── D1 (Asset Catalog — optional) ──────────────────────────────────────────
# CLOUDFLARE_D1_OBJECTSTORE_ID=your-d1-database-uuid
# CLOUDFLARE_USER_API=your-cloudflare-user-api-token

# ── Discord OAuth ───────────────────────────────────────────────────────────
# DISCORD_CLIENT_ID=your-discord-client-id
# DISCORD_CLIENT_SECRET=your-discord-client-secret

# ── Puter (deployer token for server-side KV/FS) ───────────────────────────
# PUTER_AUTH_TOKEN=your-puter-deployer-token

# ── Multiplayer (Colyseus Cloud) ────────────────────────────────────────────
# COLYSEUS_CLOUD_TOKEN=your-colyseus-cloud-token

# ── Domains ─────────────────────────────────────────────────────────────────
DOMAIN_API=api.grudge-studio.com
DOMAIN_ASSETS=assets.grudge-studio.com
DOMAIN_CLIENT=client.grudge-studio.com

# ── Vite (client-side, exposed to browser) ──────────────────────────────────
# VITE_ASSET_CDN_URL=https://assets.grudge-studio.com/grudge-nexus
VITE_GRUDGE_API_BASE=https://api.grudge-studio.com
# VITE_DISCORD_CLIENT_ID=your-discord-client-id-for-frontend
# VITE_WEB3AUTH_CLIENT_ID=your-web3auth-client-id
# VITE_WEB3AUTH_NETWORK=sapphire_devnet
