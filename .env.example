# ═══════════════════════════════════════════════════════════════════════════
# Grudge Nexus — Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://grudge:grudge_dev@localhost:5432/grudge_nexus
POSTGRES_PASSWORD=grudge_dev

# ── API Server ──────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Admin token for protected routes (auto-generated if unset in dev)
# ADMIN_TOKEN=your-secret-admin-token

# Comma-separated allowed origins. Omit in dev to allow all.
# CORS_ORIGINS=https://grudgewarlords.com,https://grudge-studio.com,https://client.grudge-studio.com

# ── Cloudflare R2 (Object Storage) ─────────────────────────────────────────
CF_ACCOUNT_ID=your-cloudflare-account-id
OBJECT_STORAGE_KEY=your-r2-access-key-id
OBJECT_STORAGE_SECRET=your-r2-secret-access-key
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_PUBLIC_URL=https://assets.grudge-studio.com
# OBJECT_STORAGE_PUBLIC_R2_URL=https://pub-xxxx.r2.dev

R2_BUCKET_ASSETS=grudge-assets
R2_BUCKET_OBJECTSTORE=objectstore-assets

# ── Cloudflare D1 (Asset Catalog — optional) ───────────────────────────────
# D1_ACCOUNT_ID=
# D1_DATABASE_ID=
# D1_API_TOKEN=

# ── Asset CDN (Vite client-side) ───────────────────────────────────────────
# Set this to serve game assets from R2 instead of the local public/ dir.
# When unset, assets load from the Vite dev server (local dev mode).
# VITE_ASSET_CDN_URL=https://assets.grudge-studio.com/grudge-nexus

# ── Puter (Identity — browser-side, no server config needed) ───────────────
# The Puter.js SDK is loaded via <script> tag in the game client HTML.
# No env vars needed server-side. For deployer-paid backend operations:
# PUTER_DEPLOYER_TOKEN=your-puter-deployer-token
